# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me

# Comma-separated Telegram numeric user IDs. Use /id in the bot to find yours.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Linux command execution
BOT_WORKDIR=/opt/telegram-codex-bot/workdir
COMMAND_TIMEOUT_SECONDS=60
MAX_OUTPUT_CHARS=3500

# Keep false unless you really want arbitrary shell execution from Telegram.
ALLOW_UNSAFE_COMMANDS=false

# Safe mode only. Prefixes are matched as argv tokens, not raw shell strings.
ALLOWED_COMMAND_PREFIXES=uptime,whoami,pwd,ls,df -h,free -h,systemctl status,docker ps,journalctl -n

# OpenAI-compatible Chat Completions API.
AI_API_BASE_URL=https://api.openai.com
AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_API_KEY=replace_me
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=90
AI_SYSTEM_PROMPT=You are a concise assistant inside a Telegram bot.

# Codex CLI
# {prompt} is replaced with a shell-quoted prompt. Example:
# CODEX_COMMAND_TEMPLATE=codex exec {prompt}
CODEX_COMMAND_TEMPLATE=codex exec {prompt}
CODEX_WORKDIR=/opt/telegram-codex-bot/workdir
CODEX_TIMEOUT_SECONDS=300
CODEX_SESSION_CHARS=12000

